{
  "expo": {
    "name": "Lavendra Hotel",
    "slug": "hotel-frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo2.jpg",
    "scheme": "hotelfrontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1e1b4b",
        "foregroundImage": "./assets/images/logo2.jpg"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1e1b4b",
          "dark": {
            "backgroundColor": "#1e1b4b"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}